# Ignore everything by default
*

# Then whitelist only what should be in the repo
!.gitignore
!.npmignore
!package.json
!package-lock.json
!LICENSE
!README.md
!CLAUDE.md
!CHANGELOG.md
!favicon.png
!groove-logo.png

# Source packages
!packages/
!packages/daemon/
!packages/daemon/**
!packages/cli/
!packages/cli/**
!packages/gui/
!packages/gui/**
!packages/desktop/
!packages/desktop/**
!moe-training/
!moe-training/**

# But still ignore generated/installed stuff inside packages
packages/gui/dist/
packages/desktop/dist/
packages/desktop/.daemon-bundle/
**/node_modules/
**/*.log
**/*.pid
**/.DS_Store

# Never commit these
.env
.env.*
credentials.json
.groove/
.groove-staging/
.claude/

# Auto-generated by GROOVE at runtime
AGENTS_REGISTRY.md
GROOVE_DECISIONS.md
GROOVE_PROJECT_MAP.md
GROOVE_CONFLICTS.md
GROOVE_AGENT_LOGS/
