# Only needed for npm — .gitignore is whitelist-based which confuses npm
# This file tells npm what to EXCLUDE

# Tests
packages/daemon/test/

# Runtime state (contains credentials, keys, logs, state)
.claude/
**/.claude/
.groove/
**/.groove/
google-oauth.json
**/google-oauth.json

# Generated context files
GROOVE_*.md
GROOVE_AGENT_LOGS/
GROVE_*.md
AGENTS_REGISTRY.md

# Desktop app (distributed separately via GitHub Releases, not npm)
packages/desktop/

# Internal planning docs (not in git, but npm sees them)
integrations/
onboarding-flow/

# Dev/test files
example/
test-*
*.log
*.sh
.DS_Store
*.tgz
.env*
docs/

# Working dirs created during local testing / planning — never publish
trial/
plans/
.groove-staging/
bug-team/
agents-team/
electron-app/
my-workspace/
slides/
slides-creator/
elite-landscapes/
ryans-beans/
groove-dev/
archive/
