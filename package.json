{
  "name": "groove-dev",
  "version": "0.27.103",
  "description": "Open-source agent orchestration layer — the AI company OS. Local model agent engine (GGUF/Ollama/llama-server), HuggingFace model browser, MCP integrations (Slack, Gmail, Stripe, 15+), agent scheduling (cron), business roles (CMO, CFO, EA). GUI dashboard, multi-agent coordination, zero cold-start, infinite sessions. Works with Claude Code, Codex, Gemini CLI, Ollama, any local model.",
  "license": "FSL-1.1-Apache-2.0",
  "author": "Groove Dev <hello@groovedev.ai> (https://groovedev.ai)",
  "homepage": "https://groovedev.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/grooveai-dev/groove"
  },
  "bugs": {
    "url": "https://github.com/grooveai-dev/groove/issues"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "ai-coding",
    "agent-orchestration",
    "multi-agent",
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "ollama",
    "coding-assistant",
    "developer-tools",
    "devtools",
    "context-window",
    "token-savings",
    "model-routing",
    "orchestration",
    "gui",
    "dashboard",
    "process-manager",
    "llm",
    "vscode",
    "terminal"
  ],
  "bin": {
    "groove": "./packages/cli/bin/groove.js"
  },
  "workspaces": [
    "packages/daemon",
    "packages/cli",
    "packages/gui",
    "packages/desktop",
    "packages/launch-page",
    "moe-training"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:daemon": "npm run dev -w packages/daemon",
    "dev:gui": "npm run dev -w packages/gui",
    "build": "npm run build -w packages/gui",
    "start:desktop": "npm run start -w packages/desktop",
    "build:desktop": "npm run build -w packages/desktop",
    "dist:desktop": "npm run build && npm run dist -w packages/desktop",
    "test": "node --test packages/daemon/test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "bundleDependencies": [
    "@groove-dev/daemon",
    "@groove-dev/cli",
    "@groove-dev/gui",
    "moe-training"
  ]
}
